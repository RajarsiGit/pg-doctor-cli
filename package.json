{
  "name": "pg-doctor-cli",
  "version": "0.1.0",
  "description": "A portable Postgres diagnostic CLI: bloat, long-running queries, lock chains, connection saturation, and replication lag checks against any Postgres instance.",
  "keywords": [
    "postgres",
    "postgresql",
    "database",
    "diagnostics",
    "cli",
    "devops",
    "dba"
  ],
  "license": "GPL-3.0-or-later",
  "bin": {
    "pg-doctor": "bin/pg-doctor.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^5.4.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.10",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
